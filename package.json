  "repository": {
    "type": "git",
    "url": "https://git.ikilote.net/typescript/json2html"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:lib": "vitest run projects/json2html --coverage",
    "test:lib": "vitest run projects/json2html",
    "test:app": "vitest run src/app",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "publish:lib": "cd dist/json2html && npm publish ",
    "build:lib": "ng build json2html --configuration production && cp *.md dist/json2html && cp LICENSE dist/json2html",
    "build:demo": "ng build --configuration production",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
