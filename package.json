{
  "name": "@ikilote/json2html-demo",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://git.ikilote.net/typescript/json2html"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:lib": "vitest run projects/json2html --coverage",
    "test:lib": "vitest run projects/json2html",
    "test:app": "vitest run src/app",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "publish:lib": "cd dist/json2html && npm publish ",
    "build:lib": "ng build json2html --configuration production && cp *.md dist/json2html && cp LICENSE dist/json2html",
    "build:demo": "ng build --configuration production",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@ikilote/magma": "^1.8.1",
    "core-js": "^3.49.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.2",
    "@angular-devkit/build-angular": "^22.0.5",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.1",
    "prettier": "^3.9.4",
    "prettier-plugin-css-order": "^2.2.0",
    "ts-node": "~10.9.2",
    "tslint": "~6.1.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "typescript",
    "html",
    "json",
    "xml",
    "json-to-html"
  ]
