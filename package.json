    "@types/node": "^12.11.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.2",
    "jsdom": "^29.1.1",
    "ng-packagr": "^21.2.5",
    "prettier": "^3.5.3",
