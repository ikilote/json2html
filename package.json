    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@ikilote/magma": "^0.9.2",
    "colorjs.io": "^0.5.2",
    "core-js": "^2.5.4",
    "ng-select2-component": "^17.2.7",
    "rxjs": "^7.8.2",
    "tslib": "^2.0.0",
    "zone.js": "~0.15.0"
